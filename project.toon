  benchmarks/thermodynamic_benchmark.py:
    i: asyncio,time,sys,numpy,dataclasses.dataclass,nlp2cmd.generation.thermodynamic.create_thermodynamic_generator,pathlib.Path,typing.{Any,Dict,List}
    e: BenchmarkResult,benchmark_langevin_sampler,benchmark_parallel_vs_sequential,benchmark_adaptive_steps,benchmark_generator_problems,benchmark_energy_savings,print_benchmark_result,main
    BenchmarkResult:   # Result of a benchmark run.
    benchmark_langevin_sampler(n_iterations:int=10;n_steps:int=200;dim:int=20)->BenchmarkResult
    benchmark_parallel_vs_sequential(n_samples:int=5;n_steps:int=100;dim:int=10)->tuple[BenchmarkResult,BenchmarkResult]
    benchmark_adaptive_steps(problem_sizes:List[int]=[2; 5; 10; 20])->List[BenchmarkResult]
    benchmark_generator_problems(n_iterations:int=5)->List[BenchmarkResult]
    benchmark_energy_savings()->Dict[str,Any]
    print_benchmark_result(result:BenchmarkResult)
    main()
