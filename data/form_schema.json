{
  "$schema": "form_schema.v1",
  "description": "Schema for automatic form field detection and filling",
  
  "nlp_keywords": {
    "typing": ["wpisz", "wpisać", "wpisac", "type", "input", "napisz", "fill"],
    "clicking": ["kliknij", "click", "naciśnij", "nacisnij", "press"],
    "form": ["formularz", "form", "wypełnij", "wypelnij", "fill out", "fill form", "znajdź formularz", "znajdz formularz", "znajdź formularz kontaktowy", "znajdz formularz kontaktowy", "szukaj formularza", "przeszukaj formularz", "znajdź stronę kontaktu", "znajdz strone kontaktu", "szukaj kontaktu", "znajdź kontakt", "znajdz kontakt"],
    "submit": ["wyślij", "wyslij", "submit", "send", "prześlij", "przeslij", "zatwierdź", "zatwierdz"],
    "press_enter": ["naciśnij enter", "nacisnij enter", "wciśnij enter", "wcisnij enter", "press enter", "hit enter", "enter"],
    "fill_form_phrases": ["wypełnij formularz", "wypelnij formularz", "fill form", "fill the form", "fill out the form", "fill in the form", "znajdź formularz", "znajdz formularz", "znajdź formularz kontaktowy", "znajdz formularz kontaktowy", "znajdź formularz i wypełnij", "znajdz formularz i wypelnij", "znajdź stronę kontaktu i wypełnij", "znajdz strone kontaktu i wypelnij"],
    "extract_article": ["wyświetl artykuł", "wyswiетl artykul", "pokaż artykuł", "pokaz artykul", "extract article", "show article", "display article", "read article", "get article"],
    "extract_articles_plural": ["wyświetl artykuły", "wyswietl artykuly", "pokaż artykuły", "pokaz artykuly", "extract articles", "show articles", "display articles", "list articles", "get articles"],
    "extract_companies": ["znajdź firmy", "znajdz firmy", "find companies", "zbierz firmy", "lista firm", "listę firm", "liste firm", "katalog firm", "wyszukaj firmy", "firmy", "zbierz adresy", "zbierz dane firm", "extract companies", "scrape companies", "collect companies", "get companies", "list companies", "company directory", "business directory", "katalog"],
    "save_to_file": ["zapisz do pliku", "zapisz w pliku", "save to file", "write to file", "export to file", "zapisz wyniki", "zapisz dane", "save results", "save data", "do pliku", "to file"]
  },
  
  "article_topic_patterns": [
    "(?:artykuł|article)\\s+o\\s+(.+?)(?:\\s*$|\\s+i\\s)",
    "(?:artykuł|article)\\s+(?:na\\s+temat|about)\\s+(.+?)(?:\\s*$|\\s+i\\s)",
    "(?:artykuły|articles)\\s+o\\s+(.+?)(?:\\s*$|\\s+i\\s)",
    "(?:artykuły|articles)\\s+(?:na\\s+temat|about)\\s+(.+?)(?:\\s*$|\\s+i\\s)"
  ],

  "type_text_patterns": [
    "(?:wpisz|type|input|napisz)\\s+(?:w\\s+pole)?:?\\s*(.+?)(?:\\s*,?\\s*(?:oraz|and|i)\\s+(?:naciśnij|nacisnij|press|hit)\\s+(?:enter|return)|$)",
    "(?:wpisz|type|input|napisz)\\s+(?:tekst|text)?\\s*[\"'](.+?)[\"']",
    "(?:wpisz|type)\\s+(.+?)(?:\\s+w\\s+pole|\\s+in\\s+field|$)"
  ],
  
  "field_mappings": {
    "name": {
      "env_var": "FORM_NAME",
      "patterns": ["imię", "imie", "name", "first_name", "firstname", "your-name", "nazwa", "name-1", "forminator-field-name"]
    },
    "lastname": {
      "env_var": "FORM_LASTNAME",
      "patterns": ["nazwisko", "surname", "last_name", "lastname"]
    },
    "email": {
      "env_var": "FORM_EMAIL",
      "patterns": ["email", "e-mail", "adres e-mail", "your-email", "mail", "email-1", "forminator-field-email"]
    },
    "phone": {
      "env_var": "FORM_PHONE",
      "patterns": ["telefon", "phone", "numer telefonu", "tel", "mobile", "phone-1", "forminator-field-phone"]
    },
    "message": {
      "env_var": "FORM_MESSAGE",
      "patterns": ["wiadomość", "wiadomosc", "message", "your-message", "treść", "tresc", "komentarz", "comment", "textarea-1", "forminator-field-textarea"]
    },
    "subject": {
      "env_var": "FORM_SUBJECT",
      "patterns": ["temat", "subject"]
    },
    "company": {
      "env_var": "FORM_COMPANY",
      "patterns": ["firma", "company", "organization"]
    },
    "address": {
      "env_var": "FORM_ADDRESS",
      "patterns": ["adres", "address"]
    },
    "city": {
      "env_var": "FORM_CITY",
      "patterns": ["miasto", "city"]
    },
    "website": {
      "env_var": "FORM_WEBSITE",
      "patterns": ["strona", "website", "url"]
    },
    "consent": {
      "env_var": "FORM_CONSENT",
      "patterns": ["zgoda", "consent", "rodo", "gdpr", "akceptuję", "akceptuje", "accept", "agree", "zgadzam", "polityka", "regulamin", "terms", "privacy"]
    }
  },
  
  "submit_selectors": [
    "button[type=\"submit\"]",
    "input[type=\"submit\"]",
    "button:has-text(\"Wyślij\")",
    "button:has-text(\"Submit\")",
    "button:has-text(\"Send\")",
    "button:has-text(\"Prześlij\")",
    "button:has-text(\"OK\")",
    "button:has-text(\"Wylij\")",
    "button:has-text(\"Wyslij\")",
    "input[value*=\"Wyślij\"]",
    "input[value*=\"Wyslij\"]",
    "input[value*=\"Send\"]",
    ".submit-button",
    ".wpcf7-submit",
    "[type=\"submit\"]",
    "button.btn",
    "input.btn"
  ],
  
  "skip_fields": ["sl", "tl", "query", "gtrans", "vote", "honeypot", "bot", "captcha", "hidden"],
  
  "type_selectors": {
    "search": [
      "input[name='q']",
      "input[type='search']",
      "textarea[name='q']",
      "textarea[aria-label*='Search']",
      "textarea[aria-label*='Szukaj']",
      "input[aria-label*='Search']",
      "input[aria-label*='Szukaj']",
      "textarea",
      "input[type='text']"
    ],
    "generic": [
      "textarea",
      "input[type='text']",
      "input"
    ]
  },
  
  "save_filename_patterns": [
    "(?:zapisz|save|write|export)\\s+(?:do|to|w|in)\\s+(?:pliku?)?\\s*['\"]?([\\w._-]+\\.\\w+)['\"]?",
    "(?:do|to)\\s+pliku\\s*['\"]?([\\w._-]+\\.\\w+)['\"]?",
    "(?:plik|file)\\s*['\"]?([\\w._-]+\\.\\w+)['\"]?"
  ],

  "company_listing_selectors": [
    ".company-item",
    ".business-listing",
    ".firm-item",
    ".listing-item",
    ".company-card",
    ".business-card",
    "[data-company]",
    ".search-result",
    ".result-item",
    ".company",
    ".firma",
    "article.company",
    "div.company",
    "li.company"
  ],

  "company_link_selectors": [
    "a[href*='firma']",
    "a[href*='company']",
    "a[href*='business']",
    ".company-name a",
    ".business-name a",
    ".firma-name a",
    "h2 a",
    "h3 a",
    ".listing-title a",
    ".result-title a"
  ],

  "company_website_selectors": [
    "a[href*='http']:not([href*='facebook']):not([href*='twitter']):not([href*='instagram']):not([href*='linkedin'])",
    ".website a",
    ".www a",
    ".company-website a",
    "a[rel='nofollow'][href*='http']",
    "a.external-link"
  ],

  "dismiss_selectors": [
    "button:has-text('Accept all')",
    "button:has-text('Akceptuj wszystko')",
    "button:has-text('Zaakceptuj')",
    "button:has-text('Accept')",
    "button:has-text('Zgadzam się')",
    "button:has-text('I agree')",
    "button:has-text('OK')",
    "button[aria-label*='Accept']",
    "button[aria-label*='Akceptuj']",
    "button[id*='accept']",
    "button[id*='consent']",
    "#L2AGLb"
  ]
}
