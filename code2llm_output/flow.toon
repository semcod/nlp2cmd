# nlp2cmd/flow | 6817 func | 12 pipelines | 15 hub-types | 2026-03-01

PIPELINES[12] (Core:5, IO:4, NLP:2, Unknown:1):
  Networkx-3 [Core]: G → ?
              → algebraic_connectivity(G, weight, normalized, tol, method, seed) CC=6    pure ▶
              → _rcm_estimate(G, nodelist)              CC=2    pure
              → reverse_cuthill_mckee_ordering(G, heuristic) CC=1    pure
              → cuthill_mckee_ordering(G, heuristic)    CC=2    pure
              → connected_cuthill_mckee_ordering(G, heuristic) CC=4    mutation
              → pseudo_peripheral_node(G)               CC=5    pure
              → min()                                   CC=1    pure ■
              PURITY: 6/7 pure  BOTTLENECK: algebraic_connectivity(CC=6)

  Networkx-3 [Core]: G → ?
              → fiedler_vector(G, weight, normalized, tol, method, seed) CC=5    pure ▶
              → _rcm_estimate(G, nodelist)              CC=2    pure
              → reverse_cuthill_mckee_ordering(G, heuristic) CC=1    pure
              → cuthill_mckee_ordering(G, heuristic)    CC=2    pure
              → connected_cuthill_mckee_ordering(G, heuristic) CC=4    mutation
              → pseudo_peripheral_node(G)               CC=5    pure
              → min()                                   CC=1    pure ■
              PURITY: 6/7 pure  BOTTLENECK: fiedler_vector(CC=5)

  Networkx-3 [Core]: G → ?
              → spectral_ordering(G, weight, normalized, tol, method, seed) CC=6    mutation ▶
              → _rcm_estimate(G, nodelist)              CC=2    pure
              → reverse_cuthill_mckee_ordering(G, heuristic) CC=1    pure
              → cuthill_mckee_ordering(G, heuristic)    CC=2    pure
              → connected_cuthill_mckee_ordering(G, heuristic) CC=4    mutation
              → pseudo_peripheral_node(G)               CC=5    pure
              → min()                                   CC=1    pure ■
              PURITY: 5/7 pure  BOTTLENECK: spectral_ordering(CC=6)

  Networkx-3 [IO]: G → ?
              → k_edge_augmentation(G, k, avail, weight, partial) CC=11   pure ▶
              → bridge_augmentation(G, avail, weight)   CC=3    pure
              → weighted_bridge_augmentation(G, avail, weight) CC=15   mutation  !!
              → one_edge_augmentation(G, avail, weight, partial) CC=2    pure
              → weighted_one_edge_augmentation(G, avail, weight, partial) CC=6    pure
              → _lightest_meta_edges(mapping, avail_uv, avail_w) CC=4    pure
              → min()                                   CC=1    pure ■
              PURITY: 6/7 pure  BOTTLENECK: weighted_bridge_augmentation(CC=15)

  Networkx-3 [IO]: G → None
              → maximum_spanning_arborescence(G, attr, default, preserve_attrs, partition) CC=8    cache ▶
              → is_arborescence(G)                      CC=3    pure
              → is_tree(G)                              CC=4    pure
              → is_connected(G)                         CC=2    pure
              → connected_components(G)                 CC=3    mutation
              → not_implemented_for(*graph_types)       CC=10   pure
              → set(name:str, value:Any) → None         CC=1    pure ■
              PURITY: 5/7 pure  BOTTLENECK: not_implemented_for(CC=10)

  Networkx-3 [IO]: G → None
              → minimum_spanning_arborescence(G, attr, default, preserve_attrs, partition) CC=2    pure ▶
              → is_arborescence(G)                      CC=3    pure
              → is_tree(G)                              CC=4    pure
              → is_connected(G)                         CC=2    pure
              → connected_components(G)                 CC=3    mutation
              → not_implemented_for(*graph_types)       CC=10   pure
              → set(name:str, value:Any) → None         CC=1    pure ■
              PURITY: 6/7 pure  BOTTLENECK: not_implemented_for(CC=10)

  Networkx-3 [NLP]: n → None
              → hypercube_graph(n)                      CC=1    pure ▶
              → grid_graph(dim, periodic)               CC=6    pure
              → cartesian_product(G, H)                 CC=1    pure
              → _node_product(G, H)                     CC=2    pure
              → _dict_product(d1, d2)                   CC=2    pure
              → set(name:str, value:Any) → None         CC=1    pure ■
              PURITY: 6/6 pure  BOTTLENECK: grid_graph(CC=6)

  Networkx-3 [Unknown]: n → ?
              → random_unlabeled_tree(n)                CC=4    pure ▶
              → _random_unlabeled_tree(n, cache_trees, cache_forests, seed) CC=4    mutation
              → _random_unlabeled_rooted_forest(n, q, cache_trees, cache_forests, seed) CC=4    mutation
              → _random_unlabeled_rooted_tree(n, cache_trees, seed) CC=6    mutation
              → _select_jd_trees(n, cache_trees, seed)  CC=4    pure
              → _num_rooted_trees(n, cache_trees)       CC=4    cache ■
              PURITY: 2/6 pure  BOTTLENECK: _random_unlabeled_rooted_tree(CC=6)

  Networkx-3 [Core]: G → None
              → is_bipartite_node_set(G, nodes)         CC=8    pure ▶
