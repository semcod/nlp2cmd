# NLP2CMD Service Configuration
# Generated automatically by nlp2cmd service


LITELLM_API_BASE=http://localhost:11434
LITELLM_API_KEY=
LITELLM_MAX_TOKENS=4096
#LITELLM_MODEL=ollama/qwen2.5-coder:3b
LITELLM_MODEL=ollama/qwen2.5-coder:7b

LITELLM_TEMPERATURE=0.1
LITELLM_TIMEOUT=30

# =============================================================================
# LLM Router Configuration (multi-model routing with fallbacks)
# =============================================================================
# Config file path (auto-detected from config/litellm_config.yaml)
#NLP2CMD_ROUTER_CONFIG=config/litellm_config.yaml
# Routing strategy: latency-based-routing | least-busy | simple-shuffle | usage-based-routing
#NLP2CMD_ROUTER_STRATEGY=latency-based-routing
# Verbose router logging
NLP2CMD_ROUTER_VERBOSE=false
# =============================================================================
# LLM Validator Configuration (local Ollama — runs after every command)
# =============================================================================
LLM_VALIDATOR_ENABLED=true
LLM_VALIDATOR_MODEL=qwen2.5:3b
LLM_VALIDATOR_BASE_URL=http://localhost:11434
LLM_VALIDATOR_TIMEOUT=30
LLM_VALIDATOR_TEMPERATURE=0.1

# =============================================================================
# LLM Repair Configuration (OpenRouter cloud — runs only on validator FAIL)
# =============================================================================
LLM_REPAIR_ENABLED=true
LLM_REPAIR_MODEL=openrouter/arcee-ai/trinity-large-preview:free
LLM_REPAIR_API_KEY=
LLM_REPAIR_TIMEOUT=60
LLM_REPAIR_TEMPERATURE=0.2
LLM_REPAIR_MAX_TOKENS=1500
LLM_REPAIR_DATA_DIR=

