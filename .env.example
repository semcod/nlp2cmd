# NLP2CMD Default Configuration
# Copy to .env and customize as needed

# =============================================================================
# HuggingFace Configuration
# =============================================================================
# Get token from: https://huggingface.co/settings/tokens
# Required for authenticated requests (higher rate limits)
# Use: nlp2cmd doctor --get-token  # to get token via browser
HF_TOKEN=

# HuggingFace Hub cache directory
# HF_HOME=~/.cache/huggingface

# =============================================================================
# Ollama / LLM Configuration
# =============================================================================
# Ollama server URL
OLLAMA_BASE_URL=http://localhost:11434

# Default model for action planning (canvas, complex tasks)
NLP2CMD_PLANNER_MODEL=qwen2.5:3b

# Alternative models: llama3.2, mistral, llama3.1, gemma2:2b

# Canvas LLM timeout (seconds) - increase for slow models
CANVAS_LLM_TIMEOUT=60

# Canvas LLM retries
CANVAS_LLM_RETRIES=2

# LLM Provider (anthropic, openai, ollama)
LLM_PROVIDER=ollama

# LiteLLM Configuration for NLP2CMD Schema Generation
LITELLM_MODEL=ollama/qwen2.5-coder:7b
LITELLM_API_BASE=http://localhost:11434
LITELLM_API_KEY=
LITELLM_TEMPERATURE=0.1
LITELLM_MAX_TOKENS=2048
LITELLM_TIMEOUT=30

# =============================================================================
# Browser Automation Configuration
# =============================================================================
# Default browser: firefox, chromium, webkit
PLAYWRIGHT_BROWSER=firefox

# Use existing browser instance (Firefox CDP) - PRIORITY for automation
PLAYWRIGHT_CONNECT_URL=http://localhost:9222

# Headless mode (true/false) - false shows browser window
PLAYWRIGHT_HEADLESS=false

# Slow motion delay (ms) - useful for debugging
PLAYWRIGHT_SLOW_MO=0

# Screenshot on error
PLAYWRIGHT_SCREENSHOT_ON_ERROR=true

# =============================================================================
# Web Execution Configuration
# =============================================================================
# Default timeout for web actions (ms)
WEB_ACTION_TIMEOUT=10000

# Auto-confirm dangerous actions
WEB_AUTO_CONFIRM=false

# Record video of web sessions
WEB_RECORD_VIDEO=false

# =============================================================================
# Service Configuration (for nlp2cmd service)
# =============================================================================
# Service host and port
NLP2CMD_HOST=0.0.0.0
NLP2CMD_PORT=8000

# Debug mode
NLP2CMD_DEBUG=false

# Log level: debug, info, warning, error
NLP2CMD_LOG_LEVEL=info

# CORS origins (comma-separated)
NLP2CMD_CORS_ORIGINS=*

# Max workers
NLP2CMD_MAX_WORKERS=4

# Auto-execute generated commands
NLP2CMD_AUTO_EXECUTE=false

# Session timeout (seconds)
NLP2CMD_SESSION_TIMEOUT=3600

# =============================================================================
# Ollama Timeouts
# =============================================================================
NLP2CMD_OLLAMA_TIMEOUT=5
NLP2CMD_OLLAMA_GENERATE_TIMEOUT=120
NLP2CMD_OLLAMA_PULL_TIMEOUT=300
NLP2CMD_OLLAMA_CREATE_TIMEOUT=120

# =============================================================================
# Pipeline Configuration
# =============================================================================
# Intent detection model (local or API)
INTENT_MODEL=local

# Entity extraction model
ENTITY_MODEL=local

# Confidence threshold for intent detection (0.0-1.0)
INTENT_CONFIDENCE_THRESHOLD=0.7

# Use semantic search for similar commands
SEMANTIC_SEARCH=true

# Cache directory for models and data
NLP2CMD_CACHE_DIR=~/.cache/nlp2cmd

# =============================================================================
# Polish Language Support
# =============================================================================
# Enable Polish language support
POLISH_SUPPORT=true

# Polish STT/TTS model paths (if using local models)
# VOSK_MODEL_PATH=~/.config/stts-python/models/vosk/vosk-model-small-pl-0.22

# =============================================================================
# Logging & Debugging
# =============================================================================
# Enable debug logging
DEBUG=false

# Verbose output
VERBOSE=false

# Log file path
# LOG_FILE=~/.local/share/nlp2cmd/nlp2cmd.log

# Debug log in markdown format
# DEBUG_LOG_MD=debug.md

# Show startup YAML banner (STTS style)
# STTS_STARTUP_YAML=1
# STTS_STARTUP_YAML_STDOUT=0

# =============================================================================
# Feature Flags
# =============================================================================
# Enable experimental features
EXPERIMENTAL=false

# Use vector database for pattern matching
VECTOR_DB=false

# Enable automatic error recovery
AUTO_REPAIR=false

# =============================================================================
# Personal Information (for form auto-fill)
# =============================================================================
FORM_NAME=Jan Kowalski
FORM_LASTNAME=Kowalski
FORM_EMAIL=jan.kowalski@example.com
FORM_PHONE=+48 123 456 789
FORM_MESSAGE=Dzień dobry, chciałbym uzyskać więcej informacji.
FORM_SUBJECT=Zapytanie
# FORM_COMPANY=Moja Firma Sp. z o.o.
# FORM_ADDRESS=ul. Przykładowa 1
# FORM_CITY=Warszawa
# FORM_WEBSITE=https://example.com

# =============================================================================
# Benchmark Configuration
# =============================================================================
# Benchmark output directory (default: project_root/benchmark_output)
# NLP2CMD_BENCHMARK_OUTPUT_DIR=

# Number of benchmark rounds (default: 3)
NLP2CMD_BENCHMARK_ROUNDS=3

# Benchmark models (format: name:display:params,name2:display2:params2)
NLP2CMD_TEACHER_MODEL=qwen2.5:3b
# NLP2CMD_BENCHMARK_MODELS=bielik-1.5b:Bielik-1.5B:1.5B,qwen2.5:3b:Qwen2.5-3B:3B,gemma2:2b:Gemma2-2B:2B

# Random seed for reproducible benchmark runs (default: 42)
NLP2CMD_BENCHMARK_SEED=42

# Model colors for HTML reports (comma-separated hex colors)
# NLP2CMD_BENCHMARK_COLORS=#4e79a7,#f28e2b,#e15759,#76b7b2,#59a14f

# CDN URL for Chart.js (default: https://cdn.jsdelivr.net/npm/chart.js@4)
NLP2CMD_CHART_CDN_URL=https://cdn.jsdelivr.net/npm/chart.js@4

# =============================================================================
# Evolutionary Cache Configuration
# =============================================================================
# Cache directory (default: ~/.nlp2cmd)
# NLP2CMD_CACHE_DIR=

# Additional teacher models for learning benchmark (comma-separated)
# If set, overrides the default list: qwen2.5-coder:3b, gemma2:2b
# NLP2CMD_TEACHER_MODELS=qwen2.5-coder:3b,gemma2:2b,deepseek-coder:1.3b

# Cache-specific LLM settings (override LITELLM_* for evolutionary cache)
# NLP2CMD_LLM_TEMPERATURE=0.1
# NLP2CMD_LLM_MAX_TOKENS=512
# NLP2CMD_LLM_TIMEOUT=30

# Similarity threshold for fuzzy cache matching (default: 78)
NLP2CMD_SIMILARITY_THRESHOLD=78

# =============================================================================
# Bielik Model Configuration
# =============================================================================
# Path to Bielik GGUF model file
# NLP2CMD_BIELIK_GGUF_PATH=~/.cache/bielik/bielik-1.5b.gguf

# Bielik temperature for generation (default: 0.2)
NLP2CMD_BIELIK_TEMPERATURE=0.2

# Bielik context window (default: 2048)
NLP2CMD_BIELIK_NUM_CTX=2048

# =============================================================================
# Configuration Paths
# =============================================================================
# Where to store user overrides (JSON patches, etc.).
# If unset, defaults to:
# - $XDG_CONFIG_HOME/nlp2cmd
# - ~/.config/nlp2cmd
NLP2CMD_CONFIG_DIR=

# Optional: Explicit paths to JSON files (override all other locations)
NLP2CMD_PATTERNS_FILE=
NLP2CMD_KEYWORD_DETECTOR_CONFIG=
NLP2CMD_TEMPLATES_FILE=
NLP2CMD_DEFAULTS_FILE=

# Optional: other JSON-configurable components
NLP2CMD_COMMAND_DETECTOR_FILE=
NLP2CMD_REGEX_PATTERNS_FILE=

# ===========================================
# NLP2CMD Service Configuration
# ===========================================
# Service mode settings
NLP2CMD_HOST=0.0.0.0
NLP2CMD_PORT=8000
NLP2CMD_DEBUG=false
NLP2CMD_LOG_LEVEL=info
NLP2CMD_CORS_ORIGINS=*
NLP2CMD_MAX_WORKERS=4
NLP2CMD_AUTO_EXECUTE=false
NLP2CMD_SESSION_TIMEOUT=3600

# ===========================================
# Auto-fix settings
AUTO_FIX=false


# API keys for cloud providers (optional)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ===========================================
# Benchmark Configuration
# ===========================================
# Uses LITELLM_API_BASE for Ollama connection (see above)

# Ollama timeouts (seconds)
NLP2CMD_OLLAMA_TIMEOUT=5
NLP2CMD_OLLAMA_GENERATE_TIMEOUT=120
NLP2CMD_OLLAMA_PULL_TIMEOUT=300
NLP2CMD_OLLAMA_CREATE_TIMEOUT=120

# Benchmark output directory (default: project_root/benchmark_output)
# NLP2CMD_BENCHMARK_OUTPUT_DIR=

# Number of benchmark rounds (default: 3)
# NLP2CMD_BENCHMARK_ROUNDS=3

# Benchmark models (format: name:display:params,name2:display2:params2)
# If not set, uses defaults: bielik-1.5b, qwen2.5:3b, gemma2:2b, deepseek-coder:1.3b
# NLP2CMD_BENCHMARK_MODELS=bielik-1.5b:Bielik-1.5B:1.5B,qwen2.5:3b:Qwen2.5-3B:3B,gemma2:2b:Gemma2-2B:2B

# Random seed for reproducible benchmark runs (default: 42)
# NLP2CMD_BENCHMARK_SEED=42

# Model colors for HTML reports (comma-separated hex colors)
# NLP2CMD_BENCHMARK_COLORS=#4e79a7,#f28e2b,#e15759,#76b7b2,#59a14f

# CDN URL for Chart.js (default: https://cdn.jsdelivr.net/npm/chart.js@4)
# NLP2CMD_CHART_CDN_URL=https://cdn.jsdelivr.net/npm/chart.js@4

# ===========================================
# Evolutionary Cache Configuration
# ===========================================
# Cache directory (default: ~/.nlp2cmd)
# NLP2CMD_CACHE_DIR=

# Teacher model for LLM generation (default: qwen2.5:3b)
# Can be set to override LITELLM_MODEL for specific benchmarks
NLP2CMD_TEACHER_MODEL=qwen2.5:3b

# Additional teacher models for learning benchmark (comma-separated)
# If set, overrides the default list: qwen2.5-coder:3b, gemma2:2b
# NLP2CMD_TEACHER_MODELS=qwen2.5-coder:3b,gemma2:2b,deepseek-coder:1.3b

# Cache-specific LLM settings (override LITELLM_* for evolutionary cache)
# NLP2CMD_LLM_TEMPERATURE=0.1
# NLP2CMD_LLM_MAX_TOKENS=512
# NLP2CMD_LLM_TIMEOUT=30

# Similarity threshold for fuzzy cache matching (default: 78)
NLP2CMD_SIMILARITY_THRESHOLD=78

# ===========================================
# Bielik Model Configuration
# ===========================================
# Path to Bielik GGUF model file
# NLP2CMD_BIELIK_GGUF_PATH=~/.cache/bielik/bielik-1.5b.gguf

# Bielik temperature for generation (default: 0.2)
# NLP2CMD_BIELIK_TEMPERATURE=0.2

# Bielik context window (default: 2048)
# NLP2CMD_BIELIK_NUM_CTX=2048

# ===========================================
# Where to store user overrides (JSON patches, etc.).
# If unset, defaults to:
# - $XDG_CONFIG_HOME/nlp2cmd
# - ~/.config/nlp2cmd
NLP2CMD_CONFIG_DIR=

# Optional: Explicit paths to JSON files (override all other locations)
NLP2CMD_PATTERNS_FILE=
NLP2CMD_KEYWORD_DETECTOR_CONFIG=
NLP2CMD_TEMPLATES_FILE=
NLP2CMD_DEFAULTS_FILE=

# Optional: other JSON-configurable components
NLP2CMD_COMMAND_DETECTOR_FILE=
NLP2CMD_REGEX_PATTERNS_FILE=

# Personal Information
FORM_NAME="Jan Kowalski"
FORM_LASTNAME="Kowalski"
FORM_EMAIL="jan.kowalski@example.com"
FORM_PHONE="+48 123 456 789"

# Message Content
FORM_MESSAGE="Dzień dobry, chciałbym uzyskać więcej informacji."
FORM_SUBJECT="Zapytanie"

# Business Information (optional)
# FORM_COMPANY=Moja Firma Sp. z o.o.
# FORM_ADDRESS=ul. Przykładowa 1
# FORM_CITY=Warszawa
# FORM_WEBSITE=https://example.com
