# LiteLLM Configuration for NLP2CMD Schema Generation

# LLM Provider Configuration
LITELLM_MODEL=ollama/qwen2.5-coder:7b
LITELLM_API_BASE=http://localhost:11434
LITELLM_API_KEY=

# Ollama base URL (alias for LITELLM_API_BASE when using Ollama)
# OLLAMA_BASE_URL=http://localhost:11434

# Generation Settings
# Note: These are shared between LiteLLM and Evolutionary Cache
LITELLM_TEMPERATURE=0.1
LITELLM_MAX_TOKENS=2048
LITELLM_TIMEOUT=30

# ===========================================
# NLP2CMD Service Configuration
# ===========================================
# Service mode settings
NLP2CMD_HOST=0.0.0.0
NLP2CMD_PORT=8000
NLP2CMD_DEBUG=false
NLP2CMD_LOG_LEVEL=info
NLP2CMD_CORS_ORIGINS=*
NLP2CMD_MAX_WORKERS=4
NLP2CMD_AUTO_EXECUTE=false
NLP2CMD_SESSION_TIMEOUT=3600

# ===========================================
# Form Auto-Fill Configuration
# ===========================================
# These values are used for automatic form filling
# with the "wypełnij formularz" command


# ===========================================
# Benchmark Configuration
# ===========================================
# Uses LITELLM_API_BASE for Ollama connection (see above)

# Ollama timeouts (seconds)
NLP2CMD_OLLAMA_TIMEOUT=5
NLP2CMD_OLLAMA_GENERATE_TIMEOUT=120
NLP2CMD_OLLAMA_PULL_TIMEOUT=300
NLP2CMD_OLLAMA_CREATE_TIMEOUT=120

# Benchmark output directory (default: project_root/benchmark_output)
# NLP2CMD_BENCHMARK_OUTPUT_DIR=

# Number of benchmark rounds (default: 3)
# NLP2CMD_BENCHMARK_ROUNDS=3

# Benchmark models (format: name:display:params,name2:display2:params2)
# If not set, uses defaults: bielik-1.5b, qwen2.5:3b, gemma2:2b, deepseek-coder:1.3b
# NLP2CMD_BENCHMARK_MODELS=bielik-1.5b:Bielik-1.5B:1.5B,qwen2.5:3b:Qwen2.5-3B:3B,gemma2:2b:Gemma2-2B:2B

# Random seed for reproducible benchmark runs (default: 42)
# NLP2CMD_BENCHMARK_SEED=42

# Model colors for HTML reports (comma-separated hex colors)
# NLP2CMD_BENCHMARK_COLORS=#4e79a7,#f28e2b,#e15759,#76b7b2,#59a14f

# CDN URL for Chart.js (default: https://cdn.jsdelivr.net/npm/chart.js@4)
# NLP2CMD_CHART_CDN_URL=https://cdn.jsdelivr.net/npm/chart.js@4

# ===========================================
# Evolutionary Cache Configuration
# ===========================================
# Cache directory (default: ~/.nlp2cmd)
# NLP2CMD_CACHE_DIR=

# Teacher model for LLM generation (default: qwen2.5:3b)
# Can be set to override LITELLM_MODEL for specific benchmarks
NLP2CMD_TEACHER_MODEL=qwen2.5:3b

# Additional teacher models for learning benchmark (comma-separated)
# If set, overrides the default list: qwen2.5-coder:3b, gemma2:2b
# NLP2CMD_TEACHER_MODELS=qwen2.5-coder:3b,gemma2:2b,deepseek-coder:1.3b

# Cache-specific LLM settings (override LITELLM_* for evolutionary cache)
# NLP2CMD_LLM_TEMPERATURE=0.1
# NLP2CMD_LLM_MAX_TOKENS=512
# NLP2CMD_LLM_TIMEOUT=30

# Similarity threshold for fuzzy cache matching (default: 78)
NLP2CMD_SIMILARITY_THRESHOLD=78

# ===========================================
# Bielik Model Configuration
# ===========================================
# Path to Bielik GGUF model file
# NLP2CMD_BIELIK_GGUF_PATH=~/.cache/bielik/bielik-1.5b.gguf

# Bielik temperature for generation (default: 0.2)
# NLP2CMD_BIELIK_TEMPERATURE=0.2

# Bielik context window (default: 2048)
# NLP2CMD_BIELIK_NUM_CTX=2048

# ===========================================
# Where to store user overrides (JSON patches, etc.).
# If unset, defaults to:
# - $XDG_CONFIG_HOME/nlp2cmd
# - ~/.config/nlp2cmd
NLP2CMD_CONFIG_DIR=

# Optional: Explicit paths to JSON files (override all other locations)
NLP2CMD_PATTERNS_FILE=
NLP2CMD_KEYWORD_DETECTOR_CONFIG=
NLP2CMD_TEMPLATES_FILE=
NLP2CMD_DEFAULTS_FILE=

# Optional: other JSON-configurable components
NLP2CMD_COMMAND_DETECTOR_FILE=
NLP2CMD_REGEX_PATTERNS_FILE=

# Personal Information
FORM_NAME="Jan Kowalski"
FORM_LASTNAME="Kowalski"
FORM_EMAIL="jan.kowalski@example.com"
FORM_PHONE="+48 123 456 789"

# Message Content
FORM_MESSAGE="Dzień dobry, chciałbym uzyskać więcej informacji."
FORM_SUBJECT="Zapytanie"

# Business Information (optional)
# FORM_COMPANY=Moja Firma Sp. z o.o.
# FORM_ADDRESS=ul. Przykładowa 1
# FORM_CITY=Warszawa
# FORM_WEBSITE=https://example.com
